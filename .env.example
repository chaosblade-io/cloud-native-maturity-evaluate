# SESORA 环境变量配置模板
# 复制此文件到项目根目录并重命名为 .env，然后填入实际值
# 列表类型支持 JSON 格式（如 '["item1", "item2"]'）或逗号分隔格式（如 'item1,item2'）

# ============================================
# 阿里云基础凭证配置
# ============================================
# 阿里云 AccessKey ID
ALIBABA_CLOUD_ACCESS_KEY_ID=

# 阿里云 AccessKey Secret
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# 阿里云账号 ID（可选）
ALIBABA_CLOUD_ACCOUNT_ID=

# STS 临时凭证 Token（可选）
ALIBABA_CLOUD_SECURITY_TOKEN=

# 阿里云默认区域（默认 cn-hongkong）
ALIBABA_CLOUD_REGION=cn-hongkong

# ============================================
# ACK 容器服务配置
# ============================================
# ACK 集群 ID
ACK_CLUSTER_ID=

# 目标命名空间列表（可选，JSON格式或逗号分隔，如 '["default", "kube-system"]'）
ACK_NAMESPACES=

# 多个 kubeconfig 文件路径（可选，JSON格式或逗号分隔）
KUBECONFIG_PATHS=

# kubeconfig 上下文名称（可选）
KUBECONFIG_CONTEXT=

# ============================================
# ARMS APM 配置
# ============================================
# ARMS 工作空间 ID
ARMS_WORKSPACE_ID=

# ============================================
# ROS 资源编排配置
# ============================================
# 资源栈名称列表（可选，JSON格式，如 '["stack1", "stack2"]'）
ROS_STACK_NAME=

# ROS 所在区域（可选，默认使用 ALIBABA_CLOUD_REGION）
ROS_REGION=

# ============================================
# SLS 日志服务配置
# ============================================
# SLS Project 名称
SLS_PROJECT=

# SLS Logstore 列表（可选，JSON格式或逗号分隔）
SLS_LOGSTORES=

# SLS 所在区域（可选，默认使用 ALIBABA_CLOUD_REGION）
SLS_REGION=

# ============================================
# 云效 Codeup 配置
# ============================================
# 云效个人访问令牌
# 获取方式: 云效控制台 -> 个人设置 -> 个人访问令牌
YUNXIAO_TOKEN=

# 云效组织 ID
# 获取方式: 云效控制台 -> 组织管理 -> 基本信息 -> 组织 ID
CODEUP_ORG_ID=

# 仓库 ID 列表（可选，JSON格式或逗号分隔）
CODEUP_REPO_IDS=

# 流水线 ID 列表（可选，JSON格式或逗号分隔）
CODEUP_PIPELINE_IDS=

# Codeup 项目名称（可选）
CODEUP_PROJECT_NAME=

# ============================================
# 函数计算 FC 配置
# ============================================
# 函数名称列表（可选，JSON格式或逗号分隔）
FC_FUNCTION_NAMES=

# ============================================
# EventBridge 配置
# ============================================
# EventBridge 总线名称列表（可选，JSON格式或逗号分隔）
EVENTBRIDGE_BUS_NAMES=

# ============================================
# RDS 数据库配置
# ============================================
# RDS 实例 ID 列表（可选，JSON格式或逗号分隔，如 '["rm-xxx", "rm-yyy"]'）
RDS_INSTANCE_IDS=

# RDS 所在区域（可选，默认使用 ALIBABA_CLOUD_REGION）
RDS_REGION=

# ============================================
# OSS 对象存储配置
# ============================================
# OSS Bucket 名称列表（可选，JSON格式或逗号分隔）
OSS_BUCKET_NAMES=

# OSS 所在区域（可选，默认使用 ALIBABA_CLOUD_REGION）
OSS_REGION=

# ============================================
# ACR 容器镜像服务配置
# ============================================
# ACR 实例 ID 列表（可选，JSON格式或逗号分隔）
ACR_INSTANCE_IDS=

# 仅采集 Otel 相关镜像（可选，默认 true）
ACR_OTEL_ONLY=true

# ============================================
# ALB 应用负载均衡配置
# ============================================
# ALB 负载均衡器 ID 列表（可选，JSON格式或逗号分隔）
ALB_LOAD_BALANCER_IDS=

# ============================================
# Istio 服务网格配置
# ============================================
# Istio 配置通过 KUBECONFIG_PATHS 自动获取，无需额外配置
# 确保 kubeconfig 可以访问安装了 Istio 的集群

# ============================================
# ECS 云服务器配置
# ============================================
# ECS 所在区域（可选，默认使用 ALIBABA_CLOUD_REGION）
ECS_REGION=

# ============================================
# GTM 全局流量管理配置
# ============================================
# GTM 实例 ID
GTM_INSTANCE_ID=

# ============================================
# Grafana 配置
# ============================================
# Grafana 工作空间 ID
GRAFANA_WORKSPACE_ID=

# ============================================
# ArgoCD 配置
# ============================================
# ArgoCD 服务器地址
ARGOCD_SERVER=

# ArgoCD 访问令牌
ARGOCD_TOKEN=
